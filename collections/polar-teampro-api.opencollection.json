            "params": [
              {
                "name": "player_session_id",
                "value": "",
                "type": "path",
                "description": "Players' training session id."
              },
              {
                "name": "samples",
                "value": "distance,location,hr",
                "type": "query",
                "description": "Include requested samples in response. Possible values are \"all\" or comma-separated list from \"distance\", \"location\", \"hr\", \"speed\", \"cadence\", \"altitude\", \"forward_acceleration\", \"rr\"."
              }
            ],
